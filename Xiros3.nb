Cell[CellGroupData[{

Cell["\<\
\[CapitalDelta]\[Upsilon]\[Nu]\[Alpha]\[Mu]\[Iota]\[Kappa]\:03cc \[Kappa]\
\[Alpha]\[Iota] \
\[CurlyEpsilon]\[Nu]\:03ad\[Rho]\[Gamma]\[CurlyEpsilon]\[Iota]\[Alpha]
\
\>", "Section",
 CellChangeTimes->{{3.9816882822758694`*^9, 
  3.981688315496952*^9}},ExpressionUUID->"fa777f62-9b03-4e39-adc2-\
41faf2ac5b63"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Remove", "[", 
   RowBox[{"x", ",", "p", ",", "\[Omega]"}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"U", "[", "x_", "]"}], "=", 
  RowBox[{"\[Integral]", 
   RowBox[{
    RowBox[{"\[Omega]", "^", "2"}], 
    RowBox[{"\[DifferentialD]", "x"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{"gr1", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"U", "[", "x", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "2"}], ",", "3"}], "}"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.9816883253522387`*^9, 3.9816884171226406`*^9}, {
  3.98169029270222*^9, 
  3.9816903301025195`*^9}},ExpressionUUID->"57d28138-cd4b-4daa-9f31-\
3803ce27598b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"eqpoints", "=", 
   RowBox[{"NSolve", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"f", "[", "x", "]"}], "==", "0"}], ",", "x"}], "]"}]}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]"}]], "Input",
 CellChangeTimes->{{3.981690410803774*^9, 3.981690467725591*^9}},
 CellLabel->"In[22]:=",ExpressionUUID->"d2587007-39c9-43d9-ac64-866314ff6782"]
}, Open  ]],

