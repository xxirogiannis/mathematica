Cell[BoxData[{
 RowBox[{"deq", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"x", "''"}], "[", "t", "]"}], "+", 
    RowBox[{"Sin", "[", 
     RowBox[{"x", "[", "t", "]"}], "]"}]}], "==", 
   "0"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"x0", "=", 
   RowBox[{"\[Pi]", "/", "6"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"p0", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tmax", "=", "300"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"sol", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"deq", ",", 
      RowBox[{
       RowBox[{"x", "[", "0", "]"}], "==", "x0"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "'"}], "[", "0", "]"}], "==", "p0"}]}], "}"}], ",", "x", 
    ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "tmax"}], "}"}], ",", 
    RowBox[{"MaxSteps", "->", "1000"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"xt", "[", "t_", "]"}], "=", 
