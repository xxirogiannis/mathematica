Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"deq", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"x", "''"}], "[", "t", "]"}], "+", 
    RowBox[{"Sin", "[", 
     RowBox[{"x", "[", "t", "]"}], "]"}]}], "==", 
   "0"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"x0", "=", 
   RowBox[{"\[Pi]", "-", 
    SuperscriptBox["10", 
     RowBox[{"-", "5"}]]}]}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"p0", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tmax", "=", "3000"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"sol", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"deq", ",", 
      RowBox[{
       RowBox[{"x", "[", "0", "]"}], "==", "x0"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "'"}], "[", "0", "]"}], "==", "p0"}]}], "}"}], ",", "x", 
    ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "tmax"}], "}"}], ",", 
    RowBox[{"MaxSteps", "->", "Infinity"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"xt", "[", "t_", "]"}], "=", 
  RowBox[{
   RowBox[{"x", "[", "t", "]"}], "/.", 
   RowBox[{"sol", "[", 
    RowBox[{"[", "1", "]"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"xt", "[", "t", "]"}], ",", 
